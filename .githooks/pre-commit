#!/usr/bin/env bash
set -euo pipefail

# Repo-local pre-commit hook for the DCS agent harness.
# Keeps commits clean by auto-fixing lint + formatting on staged Python files.

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

files=()
while IFS= read -r line; do
  [[ -n "$line" ]] && files+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACM | grep -E '\.py$' || true)

if [[ ${#files[@]} -eq 0 ]]; then
  exit 0
fi

# Lint (with auto-fix) + format staged Python files.
uv run ruff check --fix -- "${files[@]}"
uv run ruff format -- "${files[@]}"

# Restage any modifications from ruff.
git add -- "${files[@]}"

# Enforce clean state for staged files.
uv run ruff check -- "${files[@]}"
uv run ruff format --check -- "${files[@]}"

exit 0
